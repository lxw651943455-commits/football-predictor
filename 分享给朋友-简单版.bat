@echo off
chcp 65001 >nul
echo ===============================================
echo   分享给朋友 - 查看你的本机 IP
echo ===============================================
echo.
echo 正在获取本机 IP 地址...
echo.

ipconfig | findstr "IPv4" | findstr /v "127.0.0.1"

echo.
echo ===============================================
echo   分享步骤：
echo ===============================================
echo.
echo 1. 复制上面的 IP 地址（例如 192.168.1.100）
echo.
echo 2. 确保朋友连接到同一个 Wi-Fi 或网络
echo.
echo 3. 把这个地址发给朋友：
echo.
echo    http://你的IP:3001
echo.
echo    例如：http://192.168.1.100:3001
echo.
echo ===============================================
echo.
echo 【注意】
echo - 朋友需要在同一个网络（Wi-Fi）中
echo - 如果无法访问，检查防火墙设置
echo.
pause
